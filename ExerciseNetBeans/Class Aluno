package com.mycompany.exercise;

public class Aluno {
    
    public double calcularMedia(double n1, double n2, double n3) {
    double media = (n1 + n2 + n3) / 3;
    return media;
    }
    
    public String verificarSituacao(double media) {
    if (media >= 6) {
        return "Aprovado";
    } else if (media >= 5) {
        return "Recuperação";
    } else {
        return "Reprovado";
    }
}
}
