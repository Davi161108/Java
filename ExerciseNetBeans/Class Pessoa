package com.mycompany.exercise;

    public class Pessoa {
    // atributos privados
    private String nome;
    private int idade;

    // getters
    public String getNome() {
        return nome;
    }

    public int getIdade() {
        return idade;
    }

    // setters
    public void setNome(String nome) {
        this.nome = nome;
    }

    public void setIdade(int idade) {
        this.idade = idade;
    }

    // método apresentar
    public void apresentar() {
        System.out.println("Olá, meu nome é " + nome + " e tenho " + idade + " anos.");
    }
}
