package aparelho;

public class Celular {
    String modelo;
    int ano;
    String cor;
    
    void ligar(){
        System.out.println("Helloo" +modelo);
    }
    
    void info(){
        System.out.println("O aparelho é um "+modelo+" ano "+ano+", da cor" +cor);
    }
  
}
