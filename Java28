package qualquer;

import java.util.Scanner;

public class Qualquer {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // Criando um vetor com 7 números
        int[] numeros = {10, 25, 30, 45, 50, 65, 80};

        // Usuário digita o valor
        System.out.print("Digite um número para buscar: ");
        int valor = sc.nextInt();

        boolean encontrado = false;

        // Verificando se o valor está presente
        for (int i = 0; i < numeros.length; i++) {
            if (numeros[i] == valor) {
                encontrado = true;
                break;
            }
        }

        // Resultado
        if (encontrado) {
            System.out.println("O valor " + valor + " está presente no vetor.");
        } else {
            System.out.println("O valor " + valor + " não está presente no vetor.");
        }

        sc.close();
    }
}
