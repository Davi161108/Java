public class Qualquer {
    public static void main(String[] args) {
        String texto = "Gabi linda";
        int cont = 0;

        for (int i = 0; i < texto.length(); i++) {
            char c = texto.charAt(i);

            if (c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u') {
                cont++;
            }
        }

        System.out.println(cont);
    }
}
